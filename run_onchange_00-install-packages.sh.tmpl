{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
set -euo pipefail

echo "==> Installing Homebrew packages..."

brew bundle --file=/dev/stdin <<EOF
# Shell
brew "bat"
brew "fzf"
brew "direnv"
brew "the_silver_searcher"
brew "tmux"
brew "sshs"

# Editor
brew "neovim"

# Dev tools
brew "gh"
brew "jq"
brew "yq"

# Runtime
brew "fnm"

# Cloud
brew "awscli"

# Casks
cask "ngrok"
cask "stats"
EOF

echo "==> Homebrew packages installed."
{{- else if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
set -euo pipefail

echo "==> Installing apt packages..."

sudo apt-get update -qq
sudo apt-get install -y -qq \
  zsh \
  tmux \
  bat \
  fzf \
  fd-find \
  ripgrep \
  jq \
  curl \
  git \
  wget \
  unzip

# Install latest Neovim via AppImage (apt version is too old)
echo "==> Installing latest Neovim..."
curl -Lo /tmp/nvim-linux-x86_64.appimage https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.appimage
chmod u+x /tmp/nvim-linux-x86_64.appimage
mkdir -p ~/.local/bin
mv /tmp/nvim-linux-x86_64.appimage ~/.local/bin/nvim

# Symlink batcat -> bat (Ubuntu names it batcat)
if command -v batcat &>/dev/null && ! command -v bat &>/dev/null; then
  mkdir -p ~/.local/bin
  ln -sf "$(command -v batcat)" ~/.local/bin/bat
fi

# Symlink fdfind -> fd (Ubuntu names it fdfind)
if command -v fdfind &>/dev/null && ! command -v fd &>/dev/null; then
  mkdir -p ~/.local/bin
  ln -sf "$(command -v fdfind)" ~/.local/bin/fd
fi

# Install gh (GitHub CLI) if not present
if ! command -v gh &>/dev/null; then
  echo "==> Installing GitHub CLI..."
  (type -p wget >/dev/null || sudo apt-get install wget -y) \
    && sudo mkdir -p -m 755 /etc/apt/keyrings \
    && out=$(mktemp) \
    && wget -nv -O"$out" https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    && cat "$out" | sudo tee /etc/apt/keyrings/githubcli-archive-keyring.gpg > /dev/null \
    && sudo chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | sudo tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && sudo apt-get update -qq \
    && sudo apt-get install -y -qq gh
fi

# Install eza if not present
if ! command -v eza &>/dev/null; then
  echo "==> Installing eza..."
  sudo mkdir -p /etc/apt/keyrings
  wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc | sudo gpg --dearmor -o /etc/apt/keyrings/gierens.gpg
  echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" | sudo tee /etc/apt/sources.list.d/gierens.list
  sudo chmod 644 /etc/apt/keyrings/gierens.gpg
  sudo apt-get update -qq
  sudo apt-get install -y -qq eza
fi

# Install zoxide if not present
if ! command -v zoxide &>/dev/null; then
  echo "==> Installing zoxide..."
  curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
fi

# Install fnm if not present
if ! command -v fnm &>/dev/null; then
  echo "==> Installing fnm..."
  curl -fsSL https://fnm.vercel.app/install | bash -s -- --skip-shell --install-dir "$HOME/.local/bin"
fi

echo "==> Linux packages installed."
{{- end }}
